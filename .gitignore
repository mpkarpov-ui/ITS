# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

docs/

# uv (uv.lock is committed; caches are not)
.uv/

# Node / pnpm
node_modules/
.pnpm-store/
*.tsbuildinfo

# Generated artifacts (CLAUDE.md hard rule: schemas are source of truth, types are generated)
packages/contracts/src/its_contracts/*.py
packages/contracts/src/its_contracts/*.pyi
!packages/contracts/src/its_contracts/__init__.py
!packages/contracts/src/its_contracts/_loader.py
!packages/contracts/src/its_contracts/codegen.py
packages/contracts/types/
packages/contracts/.codegen-cache.json

# Per-plugin derived schemas next to their .py sources (the .py is source-of-
# truth, .json is generated by codegen and re-derived on each run).
plugins/*/schemas/*.json

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Env
.env
.env.local
.env.*.local

# Logs
*.log
logs/

# ITS runtime data, if anything ever lands inside the repo
.its/
